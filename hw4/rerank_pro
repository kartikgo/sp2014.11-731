def binary_search(inlist,query,i,j):
	if i==len(inlist):
		return "You Idiot!"
	if j==i:
		return i
	if (((j-i)==1) and (inlist[i]<query)):
		return j
	candidate = (i+j)/2
	if inlist[candidate]== query:
		return candidate
	if inlist[candidate] < query:
		return binary_search(inlist,query,candidate,j)
	elif inlist[candidate] > query:
		return binary_search(inlist,query,i,candidate)
# We know that the lists are sorted! So, merge sort might be the best
def merge_sort(list1,list2):
	#print type(list1),type(list2)
	if (list1==[]):
		#print "empty stuff"
		return list2
	# if list2 is outside list1
	elif not(list1[-1][1] > list2[0][1]):
		list1.extend(list2)
		return list1
	# if list1 is outside list2
	elif not(list2[-1][1] > list1[0][1]):
		list2.extend(list1)
		return list2
	else:
		result=[]
		l_id,r_id = 0, 0
		while l_id < len(list1) and r_id < len(list2):
			if list1[l_id][1] <= list2[r_id][1]:
				result.append(list1[l_id])
				l_id +=1
			else:
				result.append(list2[r_id])
				r_id += 1
		if ((l_id == len(list1)) and not(r_id == len(list2))):
			result += list2[r_id:]
		if ((r_id == len(list2))and not(l_id == len(list1))):
			result += list1[l_id:]
		return result
	

def sample(weights,num_samples):
	totals = []
	running_total = 0

	for ind,w,tr in weights:
		running_total += w
		totals.append(running_total)
	mx= len(totals)
	cand= ''
	cand1=''
	i=0
	done=[]
	seen=[]
	while i < num_samples:
		rnd = random.random() * running_total
		to_add = binary_search(totals,rnd,0,mx)
		cand= weights[to_add]
		if not(to_add in done):
			i += 1
			done.append(to_add)
			yield cand
		else:
			continue
	

