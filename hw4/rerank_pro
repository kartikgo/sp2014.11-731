def sendstats(s1,s2):
	u1= Counter(s1)
	u2= Counter(s2)
	yield sum((u1-u2).values())
	yield sum((u2-u1).values())
	yield sum((u1&u2).values())
	bigrams1=[]
	bigrams2=[]
	for i in xrange(len(s1)-1):
		bigrams1.append((s1[i],s1[i+1]))
	for i in xrange(len(s2)-1):
		bigrams2.append((s2[i],s2[i+1]))
	b1= Counter(bigrams1)
	b2= Counter(bigrams2)
	yield sum((b1-b2).values())
	yield sum((b2-b1).values())
	yield sum((b1&b2).values())
	trigrams1=[]
	trigrams2=[]
	for i in xrange(len(s1)-2):
		trigrams1.append((s1[i],s1[i+1],s1[i+2]))
	for i in xrange(len(s2)-2):
		trigrams2.append((s2[i],s2[i+1],s2[i+2]))
	t1= Counter(trigrams1)
	t2= Counter(trigrams2)
	yield sum((t1-t2).values())
	yield sum((t2-t1).values())
	yield sum((t1&t2).values())
